.DS_Store
*.swp
*.swo
.vscode/
.idea/

# Reader-mode output directories from /paper-trail runs (contain fetched PDFs
# and audit artifacts scoped to a specific input paper; not shareable repo content).
# Anchored to repo root so curated examples under examples/paper-trail-*/ are not excluded.
/paper-trail-*/

# Machine-local Claude Code state (per-user permissions, auto-installed skills).
# Workspace specs/scripts/prompts/commands under .claude/ are still tracked.
# Project-owned skills (committed intentionally) are carved out with `!` below.
# NOTE: `.claude/skills/*` not `.claude/skills/` — the former lets `!` exceptions
# re-include specific files; the latter ignores the directory entirely and `!`
# cannot re-include anything inside it (per git ignore rules).
.claude/settings.local.json
.claude/skills/*
!.claude/skills/doc-split-check.md
.claude/scripts/__pycache__/
*.pyc

# External benchmark datasets (fetched on demand; see data/benchmarks/*/download.sh).
# Bulk data is not committed; download scripts and READMEs are.
# NOTE: `/dir/*/` ignores the directory entirely and prevents re-include via `!`.
# Ignore contents-not-dir so re-includes work.
/data/benchmarks/*/*
!/data/benchmarks/*/download.sh
!/data/benchmarks/*/README.md

# Adapter-generated predictions, staged handles, and gold files (regeneratable).
# Gold is especially important to exclude — it must never end up in reproducible
# artifacts under source control without review.
/experiments/*/predictions/
/experiments/*/staging/
/experiments/*/gold/

# Secrets — env files that may hold API keys, OAuth tokens, GCP credentials, etc.
# Reproducibility is achieved via committed invocation shape + each reproducer supplying
# their own auth; the secret values themselves MUST NOT enter version control.
# Template files (.env.example) are allowed so the expected variables are documented.
.env
.env.local
.env.*
!.env.example

# Service-account JSON keys (GCP Vertex path). Generally stored outside the repo, but
# belt-and-suspenders in case someone drops one under the tree.
*-service-account*.json
gcp-credentials*.json
